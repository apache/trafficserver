# Test SERVER-HEADER and SERVER-URL conditions
SEND_REQUEST {
    outbound.req.X-Server-Marker = "ATS-Processed";
}

SEND_RESPONSE {
    inbound.resp.X-Server-Path = "{outbound.url.path}";
    inbound.resp.X-Server-Host-Header = "{outbound.req.Host}";

    if outbound.req.X-Server-Marker == "ATS-Processed" {
        inbound.resp.X-Marker-Found = "Yes";
    }

    if outbound.url.path ~ /^to_16\// {
        inbound.resp.X-Path-Match = "Yes";
    }
}
